[include]
	path = ~/.config/git/local.gitconfig

[core]
	excludesfile = ~/.config/git/gitignore_global

[merge]
	conflictStyle = diff3

[push]
	autoSetupRemote = true

[color.diff]
        commit = "#ffaaff"

[log]
	decorate = full

[alias]
	pf = push --force
	tree = log --graph --decorate --pretty=oneline --abbrev-commit --all
